{
  "name": "codewhisper-voice",
  "displayName": "CodeWhisper",
  "description": "Voice Ask for your editor: speak a question, send context from the file to Groq, hear the answer with ElevenLabs.",
  "version": "1.0.2",
  "publisher": "codewhisperer",
  "repository": {
    "type": "git",
    "url": "https://github.com/pulkitgovrani/codewhisper.git"
  },
  "bugs": {
    "url": "https://github.com/pulkitgovrani/codewhisper/issues"
  },
  "homepage": "https://github.com/pulkitgovrani/codewhisper#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["voice", "groq", "elevenlabs", "speech", "ai", "assistant"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codewhisper.voiceAsk",
        "title": "CodeWhisper: Voice Ask"
      },
      {
        "command": "codewhisper.installPythonDeps",
        "title": "CodeWhisper: Install Python Dependencies"
      }
    ],
    "keybindings": [
      {
        "command": "codewhisper.voiceAsk",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "CodeWhisper",
      "properties": {
        "codewhisper.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python executable (empty = python on Windows, python3 elsewhere)."
        },
        "codewhisper.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key (console.groq.com)."
        },
        "codewhisper.elevenLabsApiKey": {
          "type": "string",
          "default": "",
          "description": "ElevenLabs API key (xi-api-key)."
        },
        "codewhisper.elevenLabsVoiceId": {
          "type": "string",
          "default": "",
          "description": "ElevenLabs voice ID from the voice library."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
